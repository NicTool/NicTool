-l=100  # Max line width
-i=4    # Indent level
-ci=4   # Continuation indent cols
-b      # edit in place and backup
-se     # Errors to STDERR
-vt=1   # Maximal vertical tightness
-cti=0  # No extra indentation for closing brackets
-pt=1   # parenthesis tightness
-bt=1   # brace tightness
-sbt=1  # square bracket tightness
-bbt=1  # block brace tightness
-nsfs   # No space before semicolons
-nolq   # Don't outdent long quoted strings
-nolc   # Don't outdent long block comments
-ibc    # Indent block comments to match surrounding code
-nisbc  # Do not preserve column-1 full-line comments
-utf8
